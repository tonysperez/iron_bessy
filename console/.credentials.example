# Proxmox API Credentials for iron_bessy
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .credentials (same directory)
# 2. For each Proxmox cluster, create a section with a cluster name (arbitrary label)
# 3. Fill in the API token credentials created in Proxmox
#
# API TOKEN FORMAT:
#   - username: Format is "userid@pam!token-name" or "userid@pve!token-name"
#     Example: "packer@pve!packer-token"
#   - token: The API token secret (UUID format)
#     Get from Proxmox UI: Datacenter → Permissions → API Tokens
#
# SECURITY:
# - This file is gitignored and should NEVER be committed to version control
# - Treat as sensitive as passwords; restrict file permissions (chmod 600)
# - Rotate tokens periodically
# - Use dedicated Packer token with minimal required permissions
#
# SECTION HEADER:
# The section name (e.g., [home-lab]) is arbitrary and shown in the console menu.
# It doesn't need to match the actual cluster name, it's just useful when managing multiple environments.

[home-lab]
username = packer@pve!packer-token
token    = xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

[work]
username = packer@pve!packer-token
token    = xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
