# Packer variable overrides — applies to every image build.
# Copy this file to global_secrets.pkrvars.hcl (same directory) and fill in values.
# This file is gitignored — never commit it to version control.
#
# Pipeline account credentials (template user, ansible, breakglass) live in
# console/credentials.conf under [sys:packer] and are injected as PKR_VAR_*
# environment variables by the console. They do not belong here.
#
# Use this file to override image-specific HCL variable defaults, e.g. to use
# a different VMID or ISO path without editing the image .pkr.hcl directly.
# Note: all images share this file, so variable names must be unique across
# all images you intend to build (each image declares its own variable names).

# ── ubuntu-server-2404-core overrides ────────────────────────────────────────
# Uncomment and set to override the defaults declared in
# packer/ubuntu-server-2404-core/ubuntu-server-2404-core.pkr.hcl.

# vm_id          = 991
# vm_boot_iso    = "local:iso/ubuntu-24.04.4-live-server-amd64.iso"
