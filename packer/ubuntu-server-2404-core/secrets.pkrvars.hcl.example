# Ubuntu Template Build Credentials
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to secrets.pkrvars.hcl (same directory)
# 2. Set template_username and template_password
#
# PURPOSE:
# - These credentials are used by Packer to connect to the build VM via SSH
# - During cloud-init provisioning, a user account is created with these credentials
# - After the build completes, this account is locked (not deleted) in the template
# - Downstream provisioning (e.g., OpenTofu + cloud-init) should remove this account
#
# SECURITY:
# - This file is gitignored and should NEVER be committed to version control
# - The password is bcrypt-hashed before being stored in the image
# - Use a strong, unique password; it's only needed during the build process
# - Consider rotating the password for each build cycle
#
# NOTES:
# - The username must match the identity in cloudinit/user-data.pkrtpl (default: "packer")
# - The password is hashed by Packer's bcrypt() function during image creation
# - SSH password authentication is enabled in the template for Packer to connect
# - Post-build, consider switching to key-based authentication for deployed VMs

template_username = "packer"
template_password = "choose-a-strong-password"